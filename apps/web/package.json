{
  "name": "@cuesheet/web",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Web app for live cuesheet preview and editing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@astryxdesign/core": "*",
    "@astryxdesign/theme-neutral": "0.1.4",
    "@astryxdesign/theme-stone": "*",
    "@astryxdesign/theme-y2k": "0.1.4",
    "@cuesheet/render": "workspace:*",
    "@cuesheet/schema": "workspace:*",
    "@remotion/player": "^4.0.487",
    "@stylexjs/stylex": "^0.18.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.487"
  },
  "devDependencies": {
    "@astryxdesign/build": "*",
    "@stylexjs/unplugin": "^0.19.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser": "^2.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
